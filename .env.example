DEBUG=True
DJANGO_SECRET_KEY=some_random_long_secret_key
ALLOWED_HOSTS=127.0.0.1,localhost

DB_ENGINE=django.db.backends.postgresql
DB_NAME=myprojectdb
DB_USER=myuser
DB_PASSWORD=mypassword
DB_HOST=localhost
DB_PORT=5432

RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Gmail SMTP: enable 2-Step Verification, then create an App Password (16 chars, no spaces).
# Do not use your normal Gmail password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
# Optional; defaults to EMAIL_HOST_USER if unset
DEFAULT_FROM_EMAIL=
EMAIL_HOST_USER=your_account@gmail.com
EMAIL_HOST_PASSWORD=your_16_char_app_password

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
# Optional. On Windows, settings default to solo if unset (fixes Celery prefork + fast_trace bug).
# CELERY_WORKER_POOL=solo

# Celery Beat: OTP cleanup uses created_at; rows older than OTP_EXPIRY_MINUTES are deleted.
OTP_EXPIRY_MINUTES=15
# Daily reminder local time (uses TIME_ZONE / CELERY_TIMEZONE)
DAILY_REMINDER_HOUR=9
DAILY_REMINDER_MINUTE=0

# Optional: max upload bytes (default 6MB in settings — needed for 5MB PDFs)
# DATA_UPLOAD_MAX_MEMORY_SIZE=6291456
# FILE_UPLOAD_MAX_MEMORY_SIZE=6291456
